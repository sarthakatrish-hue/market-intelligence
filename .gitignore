# Secrets / env
.env
.env.local
.env.*.local

# Local runtime state (server.py recreates this on first run)
state.json

# Auth store — roles + access requests (must never be world-readable / committed)
auth_store.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Vite (the frontend has its own .gitignore too, this is a backstop)
node_modules/
dist/
dist-ssr/
*.log
npm-debug.log*

# Editors / OS / per-machine tooling
.claude/
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Build artefacts
*.tmp
*.bak
