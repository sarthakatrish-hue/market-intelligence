# Backend API base URL.
# Leave empty (or unset) for local dev — Vite proxies /api to localhost:8080.
# In production (Vercel), set this to the deployed backend origin, e.g.:
#   VITE_API_URL=https://scapia-intel-backend.onrender.com
VITE_API_URL=

# Supabase (added in the auth phase — leave blank for now)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry (added in the observability phase — leave blank for now)
VITE_SENTRY_DSN=
