# Anthropic / Odyssey gateway
# Local dev points at Scapia's internal gateway (requires VPN).
# In hosted deployment, point at the real Anthropic API (or whichever gateway).
ANTHROPIC_BASE_URL=https://api.odyssey.scapia.in
ANTHROPIC_API_KEY=

# ─── Deployment-phase variables (leave blank for local dev) ───────────────
# Filled in when we wire Supabase, Render, Resend, etc.

# Supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

# Resend (daily digest)
# RESEND_API_KEY=
# RESEND_FROM_ADDRESS=

# GitHub (nightly wiki snapshot)
# GITHUB_TOKEN=
# GITHUB_REPO=

# Internal cron-triggered endpoints (any random 64-byte string)
# INTERNAL_SECRET=

# Frontend origin allowed by CORS
# ALLOWED_ORIGIN=https://scapia-intel.vercel.app

# Model + guardrails (defaults live in settings.py once we migrate to FastAPI)
# ANTHROPIC_MODEL=claude-sonnet-4-7
# PER_USER_DAILY_QUERY_COUNT=30
# PER_USER_DAILY_INPUT_TOKENS=200000
# PER_USER_DAILY_OUTPUT_TOKENS=50000
# PER_INGEST_MAX_INPUT_TOKENS=100000
# PER_INGEST_MAX_OUTPUT_TOKENS=20000
# MONTHLY_BUDGET_ALERT_USD=100
# MONTHLY_HARD_KILL_USD=200
# RATE_PER_USER_PER_MIN=8
# MAX_CONCURRENT_INGESTS=2
# COST_VELOCITY_HOURLY_USD=5
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_OPEN_SECONDS=60

# Observability
# SENTRY_DSN=
